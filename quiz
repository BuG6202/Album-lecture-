<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lecture CE1</title>

<style>
body {
  font-family: Arial, sans-serif;
  background: #f7f9fc;
  text-align: center;
  margin: 0;
}

h1 {
  background: #a8d8ea;
  padding: 15px;
  margin: 0;
}

#score {
  font-size: 18px;
  margin: 10px;
}

.container {
  padding: 15px;
}

img {
  max-width: 90%;
  border-radius: 15px;
  margin: 10px 0;
}

.text {
  font-size: 20px;
  margin: 10px;
}

.button {
  display: block;
  width: 90%;
  margin: 10px auto;
  padding: 15px;
  font-size: 18px;
  border-radius: 12px;
  border: none;
  background: #d3f8e2;
}

.button.correct {
  background: #b5ead7;
}

.button.wrong {
  background: #ffb7b2;
}

#result {
  font-size: 24px;
  margin-top: 20px;
}
</style>
</head>

<body>

<h1>📚 Lecture CE1</h1>
<div id="score">Score : 0 / 0</div>

<input type="file" id="fileInput" accept=".json">

<div class="container" id="app"></div>

<script>
let data = [];
let current = 0;
let score = 0;
let total = 0;

document.getElementById("fileInput").addEventListener("change", function(event) {
  const file = event.target.files[0];
  const reader = new FileReader();

  reader.onload = function(e) {
    data = JSON.parse(e.target.result);
    total = data.length;
    current = 0;
    score = 0;
    showPage();
  };

  reader.readAsText(file);
});

function generateQuestion(text) {
  // 简单自动题目（CE1）
  return {
    question: "Que fait-on dans cette phrase ?",
    options: [
      text,
      "On mange",
      "On court"
    ],
    answer: text
  };
}

function showPage() {
  if (current >= data.length) {
    showResult();
    return;
  }

  const item = data[current];
  const q = generateQuestion(item.text);

  document.getElementById("score").innerText = `Score : ${score} / ${total}`;

  let html = `
    <img src="${item.image}" />
    <div class="text">${item.text}</div>
    <h3>${q.question}</h3>
  `;

  q.options.forEach(opt => {
    html += `<button class="button" onclick="checkAnswer(this, '${opt}', '${q.answer}')">${opt}</button>`;
  });

  document.getElementById("app").innerHTML = html;
}

function checkAnswer(btn, selected, correct) {
  if (selected === correct) {
    btn.classList.add("correct");
    score++;
  } else {
    btn.classList.add("wrong");
  }

  setTimeout(() => {
    current++;
    showPage();
  }, 800);
}

function showResult() {
  let message = "👍 Encore un effort !";

  if (score === total) {
    message = "🎉 Bravo !";
  } else if (score > total / 2) {
    message = "😊 Très bien !";
  }

  document.getElementById("app").innerHTML = `
    <div id="result">
      ${message}<br><br>
      Score final : ${score} / ${total}
    </div>
  `;
}
</script>

</body>
</html>
